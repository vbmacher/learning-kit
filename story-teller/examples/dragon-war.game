game {
    name = 'Lost in forest'

    objects {
		sword(
			name:'Kings sword',
			position: [500,1000],
			image: new File('sword.png').newInputStream()
		)
			
		dragon(
			name:'Dragon Helicop',
			position: [10,10],
			image: new File('dragon.png').newInputStream()
		)

		apple(
			name: 'Energizing apple',
			position: [100,100],
			image: new File('apple.png').newInputStream()
		)
	}

	rooms {
		start(
			name:'Sharewood land',
			image:new File('forest.png').newInputStream(),
			info: 'What you gonna do?',
			actions: [
				castle: 'Walk on the road',
				forest: 'Look into the forest'
			],
			objects: [ 'sword' ]
		)
		castle(
			name: 'Old castle',
			image:new File('castle.png').newInputStream(),
			info: 'Oh my god! Dragon! What next?',
			actions: [
				start: 'Run away...'
			],
			objects: [ 'dragon', 'apple' ]
		)
		forest(
			name: 'Deep forest',
			image: new File('forest.png').newInputStream(),
			info: 'You were killed by horrible forest monster'
		)
	}

	action { rooms, objects ->
			
		objects {
			dragon.lives = 100
			player.lives = 100

			apple.health = 10
			apple.moveable = true    
			sword.moveable = true
			
			sword.useable = { objectsInTheRoom ->
				if (objectsInTheRoom.dragon?.kill(20)) {
					WINNER
				}
			}
		
			dragon.timer = [
				start: 1,
				repeat: 1,
				action: {
					if (player.kill(20)) {
						LOSER
					}
				}
			]

		}
		
		rooms {
			current = start
			forest.init = { LOSER }
		}

	}

}


